# Flask configurations
SECRET_KEY=change-me-to-random-string
FLASK_APP=wsgi.py
FLASK_DEBUG=1

# Supabase database integration
# Pooler connection string (port 6543) for Vercel
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Direct connection string (port 5432) for running migrations locally
DIRECT_URL=postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres

# Supabase Storage client credentials
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=service_role_key
